APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8090

# Agent 后端：agentscope | aethermind | mock
AGENT_BACKEND=mock
AGENT_BACKEND_URL=http://127.0.0.1:8100
AETHERMIND_AGENT_ID=default

# 企微智能机器人（长连接，P1 启用）
WECOM_BOT_ID=
WECOM_BOT_SECRET=
WECOM_WS_URL=wss://openws.work.weixin.qq.com

# Session / 卡片状态（开发可用内存，生产用 Redis）
SESSION_STORE=memory
REDIS_URL=redis://127.0.0.1:6379/0

# 卡片模板目录（默认项目内 cards/）
CARDS_DIR=./cards
